#!/usr/bin/env bash
# Maintainer : Eduardo Charquero <eduardo.charquero@gmail.com>

pkgname=voidbr-epoptes-client
pkgver=$(date +%Y%m%d)
pkgrel=$(date +%H%M)
pkgdesc='An opensource computer lab management and monitoring tool'
replaces=(epoptes-client)
makedepends=(git python3-distutils-extra intltool)
url="https://github.com/voidlinuxbr/$pkgname"
source=("git+${url}.git")
license=(GPL3)
arch=(any)
sha256sums=('SKIP')
depends=(gobject-introspection
	gtk+3
	iperf
	iproute2
	faketime
	libnotify
	librsvg
	notification-daemon
	openssl
	python3-cairo
	python3-dbus
	python3-gobject
	python3-netifaces
	python3-openssl
	python3-service_identity
	python3-Twisted
	socat
	tigervnc
	x11vnc
	xterm
)
backup=(/etc/default/epoptes-client)

package() {
	local dirs=("usr" "etc" "opt")
	#   echo "DESTDIR=$DESTDIR"
	#   echo "pkgdir=$pkgdir"
	#   echo "srcdir=$srcdir"
	#   echo "_pkgsrc=$_pkgsrc"

	cd ${srcdir}/${pkgname}
	for dir in "${dirs[@]}"; do
		if [ -d "${_pkgsrc}/${dir}" ]; then
			cp -a "${_pkgsrc}/${dir}" "$DESTDIR/"
		fi
	done
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
  pkgname="epoptes-client"
  if ! getent group epoptes >/dev/null; then
    groupadd epoptes >/dev/null || true
    echo "Group 'epoptes' has been added."
  fi

  usermod -aG epoptes "$user" >/dev/null || true
  mkdir -p /etc/epoptes/ >/dev/null || true
  sed -i 's/import pipes/import shlex/' /usr/lib/python3.14/site-packages/epoptes/ui/gui.py || true
  sed -i 's/pipes\.quote/shlex.quote/g' /usr/lib/python3.14/site-packages/epoptes/ui/gui.py || true
  ln -sf /etc/sv/epoptes-client /var/service/ >/dev/null || true

  log "A instalação foi concluída. Antes de utilizar o Epoptes, lembre-se de fazer o seguinte:"
  log "1.- Você deverá adicionar seu usuário ao grupo 'epoptes' - ${YELLOW}sudo usermod -aG epoptes $user"
  log "2.- Você deverá executar como root:"
  log "    ${YELLOW}'vservice enable epoptes-client' ${CYAN}para habilitar o serviço de cliente Epoptes."
  log "3.- Pode ser necessário reiniciar o sistema para que tudo funcione corretamente."
  log "4.- Se não quiser reiniciar o sistema, após realizar todos os passos acima, execute como root:"
  log "    ${YELLOW}'vservice start epoptes-client' ${CYAN}para iniciar o serviço do cliente Epoptes."
  log "Após concluir tudo isso, você ainda precisará encerrar a sessão e entrar novamente."
  log "Feito isso, o Epoptes deverá funcionar normalmente.${RESET}"
}

pre_upgrade() {
	log "Iniciando upgrade"
}

post_upgrade() {
	log "Finalizando upgrade"
}
